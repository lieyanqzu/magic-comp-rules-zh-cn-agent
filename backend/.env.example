# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mtg_judge

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Chat API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding API（可独立于 Chat API）
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# 牌张查询 API
MTGCH_API_URL=https://mtgch.com/api/v1

# 规则资料根目录（相对于 backend/）
RULES_ROOT_DIR=..

# 安全配置
API_KEY=                          # 空则跳过认证，生产环境务必设置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60            # 每窗口最大请求数
RATE_LIMIT_WINDOW=60              # 窗口秒数
CORS_ORIGINS=*                    # 逗号分隔，生产环境设为实际域名

# 日志级别
LOG_LEVEL=INFO

# 应用环境
APP_ENV=development
