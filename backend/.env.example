# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mtg_judge

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Chat API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding API（可独立于 Chat API）
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# 牌张查询 API
MTGCH_API_URL=https://mtgch.com/api/v1

# 规则资料根目录（相对于 backend/）
RULES_ROOT_DIR=..

# 安全配置
# 空则跳过认证，生产环境务必设置
API_KEY=
RATE_LIMIT_ENABLED=true
# 每窗口最大请求数
RATE_LIMIT_REQUESTS=60
# 窗口秒数
RATE_LIMIT_WINDOW=60
# 反向代理 / Ingress / ALB 后必须设为 true，否则限流会以代理 IP 计数；
# 直接暴露公网时必须保持 false，否则可被伪造 X-Forwarded-For 绕过限流
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_HOPS=1
# 生产环境填实际域名，逗号分隔；不要保留 *
CORS_ORIGINS=*

# LLM 编排
LLM_MAX_TOOL_ROUNDS=5
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT=1
LLM_RETRY_MAX_WAIT=10
SSE_HEARTBEAT_INTERVAL=15

# 检索缓存
RETRIEVAL_RRF_K=60
RETRIEVAL_CACHE_TTL=300
RETRIEVAL_CACHE_ENABLED=true

# LLM 响应缓存（按归一化问题做短 TTL Redis 缓存）
LLM_CACHE_ENABLED=false
LLM_CACHE_TTL=600

# 启动时自动增量入库（基于 content_hash 比对）
# 适合规则文档作为 git 子模块、需要随子模块更新自动同步的场景。
# 流程：lifespan 启动 → 后台异步跑 ingest → 仅变更的 chunk 重新生 embedding → 删除孤儿。
# 旧数据在 commit 前持续可查，对在线请求零影响。本地频繁重启时建议关闭。
AUTO_INGEST_ON_STARTUP=false
# 自动入库时是否同步生成 embedding；关闭后启动更快，但新增/变更 chunk 没有向量
AUTO_INGEST_EMBEDDINGS=true

# 日志级别
LOG_LEVEL=INFO

# 应用环境
APP_ENV=development

# SQL echo（打印每条 SQL 与参数）。默认关闭：
# rule_chunks 含 1024 维 embedding，echo=true 时 21KB 向量字符串化打印两次会严重拖慢检索。
# 仅在排查 SQL 问题时单独打开
DB_ECHO=false
